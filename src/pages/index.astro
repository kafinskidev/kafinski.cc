---
import interFont from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2";
import serifFont from "@fontsource-variable/source-serif-4/files/source-serif-4-latin-wght-normal.woff2";
import { Icon } from "astro-icon/components";
import RotatingGreeting from "../components/RotatingGreeting.astro";
import Section from "../components/Section.astro";
import "../styles/global.css";

const title = "kafinski";
const description =
  "A 17-year-old student programmer from Poland, drawn to simple, useful, reliable software.";

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og.jpg", Astro.site).href;
const year = new Date().getFullYear();

const tools = [
  { name: "TypeScript", icon: "simple-icons:typescript" },
  { name: "Bun", icon: "simple-icons:bun" },
  { name: "Java", icon: "simple-icons:openjdk" },
  { name: "Kotlin", icon: "simple-icons:kotlin" },
  { name: "Gradle", icon: "simple-icons:gradle" },
  { name: "Rust", icon: "simple-icons:rust" },
];

const contacts = [
  {
    label: "Email",
    handle: "me@kafinski.cc",
    href: "mailto:me@kafinski.cc",
    icon: "lucide:mail",
  },
  {
    label: "GitHub",
    handle: "@kafinskidev",
    href: "https://github.com/kafinskidev",
    icon: "simple-icons:github",
  },
  {
    label: "YouTube",
    handle: "@kafinski",
    href: "https://youtube.com/@kafinski",
    icon: "simple-icons:youtube",
  },
  {
    label: "Discord",
    handle: "@kafinskidev",
    href: "https://discord.com/users/1522945763909570590",
    icon: "simple-icons:discord",
  },
];

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "kafinski",
  url: Astro.site,
  jobTitle: "Developer",
  nationality: "Polish",
  sameAs: contacts.filter((c) => c.href.startsWith("http")).map((c) => c.href),
};
---

<!doctype html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#2b4fd6" />
    <meta name="author" content="kafinski" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="preload" href={serifFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="kafinski" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="kafinski" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(person)} is:inline />
  </head>
  <body
    class="flex min-h-dvh flex-col bg-paper px-6 font-sans text-ink antialiased sm:px-8 lg:px-12"
  >
    <div class="mx-auto flex w-full max-w-page flex-1 flex-col">
      <main class="flex flex-1 flex-col justify-center py-12 sm:py-16 lg:py-20">
        <header class="motion-safe:rise pb-12 sm:pb-16">
          <h1 class="font-serif text-6xl leading-none tracking-tight sm:text-7xl lg:text-8xl">
            kafinski
          </h1>
          <p class="mt-1 text-sm text-subtle">[kaˈfiɲski]</p>
          <p class="mt-6 max-w-md text-lg leading-relaxed text-muted lg:text-xl">
            <RotatingGreeting /> I’m a 17-year-old student programmer from Poland.
            I’m drawn to software that is <strong class="font-semibold text-ink">simple, useful, and reliable</strong>.
          </p>
          <div class="mt-8">
            <a
              href="#contact"
              class="inline-flex min-h-11 items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-white transition ease-out hover:bg-accent-hover active:bg-accent-active motion-safe:active:scale-[0.97]"
            >
              <Icon name="lucide:at-sign" aria-hidden="true" class="size-4" />
              Get in touch
            </a>
          </div>
        </header>

        <Section id="tools" title="Tools" riseOrder={1}>
          <div>
            <p class="leading-relaxed text-muted text-pretty">
              What’s usually open in my editor.
            </p>
            <ul role="list" class="mt-5 flex flex-wrap gap-x-8 gap-y-4">
              {
                tools.map((tool) => (
                  <li class="flex items-center gap-2.5">
                    <Icon
                      name={tool.icon}
                      aria-hidden="true"
                      class="size-5 shrink-0 text-subtle"
                    />
                    <span class="text-sm font-medium text-muted">{tool.name}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </Section>

        <Section id="work" title="Work" riseOrder={2}>
          <div>
            <p class="leading-relaxed text-muted text-pretty">
              Just getting started. This is the first thing worth a link.
            </p>
            <a
              href="https://github.com/kafinskidev/kafinski.cc"
              target="_blank"
              rel="noopener noreferrer"
              class="group -mx-4 mt-4 block rounded-2xl p-4 transition-colors hover:bg-surface"
            >
              <span class="flex items-center justify-between gap-4">
                <span class="text-base font-semibold text-ink">kafinski.cc</span>
                <Icon
                  name="lucide:arrow-up-right"
                  aria-hidden="true"
                  class="size-4 shrink-0 text-subtle transition group-hover:text-ink motion-safe:group-hover:translate-x-0.5 motion-safe:group-hover:-translate-y-0.5"
                />
              </span>
              <p class="mt-1 max-w-xl leading-relaxed text-muted text-pretty">
                The page you’re reading.
              </p>
              <p class="mt-3 text-xs text-subtle">Astro and Tailwind CSS, 2026</p>
              <span class="sr-only">(opens in a new tab)</span>
            </a>
          </div>
        </Section>

        <Section id="contact" title="Contact" riseOrder={3}>
          <div>
            <p class="leading-relaxed text-muted text-pretty">
              Discord is where I reply fastest. Email works for anything longer.
            </p>
            <div class="mt-4 grid grid-cols-1 gap-x-8 gap-y-1 sm:grid-cols-2">
              {
                contacts.map((contact) => {
                  const external = contact.href.startsWith("http");
                  return (
                    <a
                      href={contact.href}
                      target={external ? "_blank" : undefined}
                      rel={external ? "noopener noreferrer" : undefined}
                      class="group -mx-4 flex min-h-14 items-center gap-4 rounded-2xl p-4 transition-colors hover:bg-surface"
                    >
                      <Icon
                        name={contact.icon}
                        aria-hidden="true"
                        class="size-5 shrink-0 text-subtle transition-colors group-hover:text-ink"
                      />
                      <span class="flex min-w-0 flex-col">
                        <span class="text-sm font-semibold text-ink">{contact.label}</span>
                        <span class="text-xs text-muted">{contact.handle}</span>
                      </span>
                      {external && <span class="sr-only">(opens in a new tab)</span>}
                      <Icon
                        name="lucide:arrow-up-right"
                        aria-hidden="true"
                        class="ml-auto size-4 shrink-0 text-subtle transition group-hover:text-ink motion-safe:group-hover:translate-x-0.5 motion-safe:group-hover:-translate-y-0.5"
                      />
                    </a>
                  );
                })
              }
            </div>
          </div>
        </Section>
      </main>

      <footer
        class="flex flex-col gap-1 border-t border-line pt-8 pb-8 text-sm text-subtle sm:flex-row sm:items-center sm:justify-between sm:gap-2"
      >
        <span>© {year} kafinski, Poland</span>
        <span>Set in Source Serif 4 and Inter. Built with Astro.</span>
      </footer>
    </div>
  </body>
</html>
